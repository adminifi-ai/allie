{
  "name": "allie-browser-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "worker:smoke": "node workers/browser/run.mjs --smoke .allie/worker-smoke",
    "evidence:smoke": "cargo run --locked -- run --manifest examples/login-flow.yml --out .allie/runs/v0-smoke",
    "action:smoke": "scripts/action-steps-smoke.sh",
    "auth:smoke": "scripts/auth-smoke.sh",
    "visibility:smoke": "scripts/visibility-smoke.sh",
    "coverage:smoke": "scripts/coverage-matrix-smoke.sh",
    "landscape:smoke": "scripts/landscape-smoke.sh",
    "consumer:smoke": "scripts/consumer-contract-smoke.sh",
    "consumer-cwd:smoke": "scripts/consumer-cwd-smoke.sh",
    "agentic:smoke": "scripts/agentic-smoke.sh",
    "release:smoke": "cargo run --locked -- release --packet .allie/runs/v0-smoke/evidence.json --out .allie/releases/v0-smoke --changed-surface login-form",
    "autonomous:smoke": "scripts/autonomous-smoke.sh",
    "size:smoke": "scripts/module-size-gate.sh",
    "verify": "scripts/verify.sh"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.10.2",
    "playwright": "^1.49.1"
  }
}
